# Environment variables
# Copy to apps/web/.env.local (or root .env.local)

# Runtime
NODE_ENV=development

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — loaded by @repo/db (see docs/SUPABASE_SETUP.md)
# Publishable key → NEXT_PUBLIC_SUPABASE_ANON_KEY + SUPABASE_ANON_KEY
# Secret key → SUPABASE_SERVICE_ROLE_KEY (server-only, never expose to client)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_URL=              # same as NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_ANON_KEY=         # same as NEXT_PUBLIC_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=              # optional direct Postgres connection

# AI — loaded by @repo/ai (Sprint L3.0+)
# Primary MVP path: OpenRouter + Gemini Flash (Claude not connected yet)
# OPENROUTER_API_KEY=
# AI_DEFAULT_PROVIDER=openrouter
# AI_DEFAULT_MODEL=google/gemini-2.5-flash
# OPENAI_API_KEY=              # L3.2 fallback when OpenRouter fails
# AI_FALLBACK_MODEL=gpt-4o-mini
# AI_REQUEST_TIMEOUT_MS=60000

# CI / codegen only
# SKIP_ENV_VALIDATION=true
